from __future__ import annotations
from typing import Any

def deg(v): return '?' if v is None else f'{v:.0f}°'
def ms(v): return '?' if v is None else f'{v:.1f}'

def render_markdown(result:dict[str,Any])->str:
    g=result['global']; s=result['scores']; t=s['thermal']; c=s['ceiling']; storm=result['risks']['storm']
    sector_lines=[]
    for x in result['sector_scores'][:8]: sector_lines.append(f"- **{x['sector']} starty:** {x['score']:.0f}/100 — {deg(g['direction_deg'])} — {ms(g['mean_wind_ms'])}/{ms(g['max_gust_ms'])} m/s — stabilita {g['stability_1to5']}/5")
    return '\n'.join([
      f"# Valašský PG index — {result['location']['name']} — {result['target_date']}",'',
      f"**Celkem: {s['vli']:.0f}/100**",'',result['verdict'],'',
      '## Globál','',f"- Směr: **{deg(g['direction_deg'])}**",f"- Vítr: **{ms(g['mean_wind_ms'])}/{ms(g['max_gust_ms'])} m/s**",f"- Stabilita: **{g['stability_1to5']}/5**",f"- Okno: **{result['forecast_window']['start_hour']}:00–{result['forecast_window']['end_hour']}:00**",'',
      '## Směrové sektory','',*sector_lines,'',
      '## Termika','',f"- Skóre: **{t['score']:.0f}/100**",f"- Max. teplota: **{t['max_temp_c']} °C**",f"- Průměrná oblačnost: **{t['mean_cloud_cover_pct']} %**",f"- Srážky v okně: **{t['precip_sum_mm']} mm**",'',
      '## Dostup / použitelné stoupání','',f"- Skóre: **{c['score']:.0f}/100**",f"- Slovně: **{c['label']}**",f"- Jistota: **{c['confidence']}**",f"- Poznámka: {c['note']}",'',
      '## Rizika','',f"- Bouřky/přeháňky: **{storm['risk']}**",f"- Max. pravděpodobnost srážek: **{storm['precip_probability_max_pct']} %",f"- Politika indexu: {storm['policy']}",''])
