from __future__ import annotations
import math
from statistics import mean

def clamp(v:float, lo:float=0.0, hi:float=100.0)->float: return max(lo,min(hi,v))
def angular_distance_deg(a:float,b:float)->float: return abs((a-b+180)%360-180)
def circular_mean_deg(values:list[float])->float|None:
    vals=[v for v in values if v is not None]
    if not vals: return None
    s=sum(math.sin(math.radians(v)) for v in vals); c=sum(math.cos(math.radians(v)) for v in vals)
    if abs(s)<1e-9 and abs(c)<1e-9: return None
    return (math.degrees(math.atan2(s,c))+360)%360
def safe_mean(values):
    vals=[v for v in values if v is not None]
    return mean(vals) if vals else None
def safe_max(values):
    vals=[v for v in values if v is not None]
    return max(vals) if vals else None
def safe_sum(values):
    vals=[v for v in values if v is not None]
    return sum(vals) if vals else 0.0
